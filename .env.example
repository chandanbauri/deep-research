# Copy this file to .env and adjust values as needed.
# The application loads this via python-dotenv at startup.

# Ollama server URL. Default works when Ollama runs locally.
OLLAMA_HOST=http://localhost:11434

# Default model used when --model is not passed to the CLI.
# Must be a model name returned by `ollama list`.
DEFAULT_MODEL=qwen2.5-coder:3b

# Where research outputs (reports, summaries, state files) are saved.
OUTPUT_DIR=outputs
